# ==============================================
# WEB (Next.js) - ENVIRONMENT VARIABLES EXAMPLE
# ==============================================
# Copia este archivo a .env.local y configura tus valores reales

# API Backend URL
# IMPORTANTE: Variables con NEXT_PUBLIC_ son accesibles en el browser
NEXT_PUBLIC_API_URL=http://localhost:3001

# Application URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Note: NODE_ENV is automatically set by Next.js and should NOT be defined here
