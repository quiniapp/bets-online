# Server
PORT=3001
NODE_ENV=development
API_URL=http://localhost:3001

# Database (Sequelize + Supabase PostgreSQL)
# For local Supabase: postgresql://postgres:postgres@localhost:54322/postgres
# For production Supabase: postgresql://postgres:[YOUR-PASSWORD]@db.your-project.supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:54322/postgres

# JWT
JWT_SECRET=your-jwt-secret-key-change-this-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-refresh-token-secret-change-this
JWT_REFRESH_EXPIRES_IN=7d

# Session
SESSION_SECRET=your-session-secret-change-this

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Admin Bootstrap
ADMIN_EMAIL=admin@casino.com
ADMIN_PASSWORD=change-this-password
ADMIN_USERNAME=owner
