# ==============================================
# API - ENVIRONMENT VARIABLES EXAMPLE
# ==============================================
# Copia este archivo a .env.local y configura tus valores reales

# Server
NODE_ENV=local
PORT=3001
API_URL=http://localhost:3001

# Database - Supabase Local
# Para obtener la URL de tu Supabase local, ejecuta: npx supabase status
DATABASE_URL=postgresql://postgres:postgres@localhost:55322/postgres

# JWT Secrets - GENERA NUEVOS VALORES SEGUROS
# Para generar: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-jwt-secret-min-32-characters-change-this
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-refresh-secret-min-32-characters-change-this
JWT_REFRESH_EXPIRES_IN=7d

# Session Secret - GENERA UN NUEVO VALOR SEGURO
SESSION_SECRET=your-session-secret-min-32-characters-change-this

# CORS - Orígenes permitidos
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Admin Bootstrap (usuario por defecto)
ADMIN_EMAIL=admin@casino.local
ADMIN_PASSWORD=ChangeThisPassword123!
ADMIN_USERNAME=admin

# Supabase Keys
# Obtén estos valores ejecutando: npx supabase status
SUPABASE_URL=http://127.0.0.1:55321
SUPABASE_ANON_KEY=..
SUPABASE_SERVICE_KEY=..-
