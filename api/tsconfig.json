{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "composite": true,
    "baseUrl": "./src",
    "paths": {
      "@/*": ["./*"],
      "@routes/*": ["./routes/*"],
      "@controllers/*": ["./controllers/*"],
      "@domain/*": ["./domain/*"],
      "@persistence/*": ["./persistence/*"],
      "@middleware/*": ["./middleware/*"],
      "@config/*": ["./config/*"],
      "helper": ["../../helper/src"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "tests"]
}
