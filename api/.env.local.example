# ==============================================
# 🏠 LOCAL ENVIRONMENT EXAMPLE
# ==============================================
# Copia este archivo a .env.local y configura tus valores

# Server
NODE_ENV=local
PORT=3001
API_URL=http://localhost:3001

# Database - Supabase Local
DATABASE_URL=postgresql://postgres:postgres@localhost:55322/postgres
DATABASE_URL_LOCAL=postgresql://postgres:postgres@localhost:55322/postgres

# JWT - CAMBIAR ESTOS VALORES
JWT_SECRET=your-jwt-secret-key-min-32-characters-long
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-refresh-token-secret-min-32-chars
JWT_REFRESH_EXPIRES_IN=7d

# Session
SESSION_SECRET=your-session-secret-min-32-characters-long

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Admin Bootstrap
ADMIN_EMAIL=admin@casino.local
ADMIN_PASSWORD=ChangeThisPassword123!
ADMIN_USERNAME=admin

# Supabase (ejecuta: npx supabase status para obtener estos valores)
SUPABASE_URL=http://127.0.0.1:55321
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-key
